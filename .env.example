# Copia este fichero a .env y ajusta los valores para tu entorno

# Cadena de conexión a la VM de base de datos
DATABASE_URL=postgresql+asyncpg://flight_app:CAMBIA_ESTA_PASSWORD@10.0.0.3:5432/flight_booking

# Orígenes permitidos para CORS (frontend de negocio y observability console)
# En producción, sustituir "*" por las URLs reales de esas VMs
CORS_ORIGINS=["*"]
